# ─────────────────────────────────────────────────────────────────────────────
# brainbot environment variables
# Copy this file to `.env` and fill in real values.
# Generate secret values with:   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate FERNET_KEY with:      python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
TIMEZONE=Asia/Singapore
PUBLIC_BASE_URL=https://bot.example.com

# ── Database (Docker Compose injects POSTGRES_* into the postgres container) ─
POSTGRES_USER=brainbot
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=brainbot
DATABASE_URL=postgresql+asyncpg://brainbot:change-me-strong-password@postgres:5432/brainbot

# ── Crypto: encrypts OAuth tokens at rest. NEVER rotate without re-auth. ────
FERNET_KEY=replace-with-output-of-Fernet.generate_key

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:replace-with-token-from-BotFather
TELEGRAM_WEBHOOK_SECRET=replace-with-random-32-byte-urlsafe-token
TELEGRAM_GROUP_CHAT_ID=-1001234567890

# Authorized Telegram user IDs (comma-separated). Bot ignores everyone else.
ALLOWED_USER_IDS=123456789

# Topic thread IDs inside the group (run scripts/seed_topics.py to discover)
TOPIC_DAILY_ROUTINE=2
TOPIC_EVENING_RECAP=3
TOPIC_EMAILS=4
TOPIC_CALENDAR=5
TOPIC_TODOS=6
TOPIC_SECOND_BRAIN=7
TOPIC_QUICK_NOTES=8
TOPIC_GENERAL=9

# ── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=replace-with-key-from-aistudio.google.com
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Google OAuth (Gmail + Calendar; one OAuth client covers all 3 accounts) ─
# Download credentials.json from Google Cloud Console; paste client_id + secret here,
# OR mount the file at /app/secrets/google_client.json and leave these empty.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8765/oauth/google/callback

# Logical labels used in DB to distinguish the 3 Google accounts.
GOOGLE_ACCOUNT_LABELS=main,spam1,spam2

# ── Microsoft Graph (school account) ────────────────────────────────────────
MS_CLIENT_ID=replace-with-azure-app-client-id
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:8765/oauth/microsoft/callback
MS_ACCOUNT_LABEL=school

# ── Rate limiting ───────────────────────────────────────────────────────────
WEBHOOK_RATE_LIMIT_PER_MINUTE=120
